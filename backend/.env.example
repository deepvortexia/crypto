# CoinGecko API key (optional — increases rate limits from ~30 to 500 req/min)
# Get a free key at https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Comma-separated list of allowed CORS origins (your Vercel frontend URL)
CORS_ORIGINS=https://deepvortexai.com,https://www.deepvortexai.com,http://localhost:3000

# How often to retrain models (hours). Default: 24
MODEL_RETRAIN_INTERVAL_HOURS=24

# Secret token to protect the manual /api/admin/retrain endpoint
ADMIN_SECRET=change_me_to_a_long_random_string

# Railway sets PORT automatically — do not change this in production
PORT=8000
